{
  "manifest_version": 3,
  "name": "Job Discovery - Save to Dashboard",
  "version": "1.0",
  "description": "Save jobs from any website to your Job Discovery Dashboard.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
